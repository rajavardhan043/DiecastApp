{
  "name": "diecast-gallery",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "vite",
    "build": "node scripts/generate-manifest.js && vite build",
    "build:gh-pages": "VITE_BASE_PATH=/DiecastApp/ node scripts/generate-manifest.js && vite build",
    "build:android": "npm run build && npx cap sync android",
    "apk": "bash scripts/build-apk.sh",
    "android": "npx cap open android",
    "preview": "vite preview",
    "manifest": "node scripts/generate-manifest.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/camera": "^8.0.1",
    "@capacitor/cli": "^7.5.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "formidable": "^3.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "patch-package": "^8.0.0",
    "vite": "^5.0.0"
  }
}
